    "@angular/platform-server": "21.1.5",
    "@angular/router": "21.1.5",
    "@azure/msal-angular": "5.0.4",
    "@azure/msal-browser": "5.2.0",
    "@fortawesome/fontawesome-free": "7.1.0",
